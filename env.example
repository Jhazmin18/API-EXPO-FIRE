# ==========================================
# CONFIGURACIÓN DEL BACKEND - DJANGO
# ==========================================

# Django Secret Key - CAMBIAR EN PRODUCCIÓN
SECRET_KEY=django-insecure-change-this-in-production-123456789

# Debug Mode (True para desarrollo, False para producción)
DEBUG=True

# Hosts permitidos (separados por comas)
ALLOWED_HOSTS=localhost,127.0.0.1

# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS - POSTGRESQL
# ==========================================

DB_NAME=extintores_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ==========================================
# NOTAS IMPORTANTES
# ==========================================
# 1. Copiar este archivo como .env en la raíz del proyecto backend
# 2. NO versionar el archivo .env (debe estar en .gitignore)
# 3. Cambiar SECRET_KEY y DB_PASSWORD en producción
# 4. Asegurarse de que PostgreSQL esté corriendo
# 5. Crear la base de datos antes de ejecutar migraciones:
#    CREATE DATABASE extintores_db;

